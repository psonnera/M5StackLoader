<?xml version="1.0" encoding="utf-8"?>
<!-- Adaptive icon foreground: M5Stack + Nightscout (myscout), joined by the same bolt
     shape as the original placeholder icon. Composited over @color/ic_launcher_background. -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- White plate so both marks stay legible under any launcher mask shape. -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFFFF" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- M5Stack -->
    <item
        android:width="18dp"
        android:height="18dp"
        android:left="24dp"
        android:gravity="left|center_vertical">
        <bitmap android:src="@drawable/ic_m5stack" />
    </item>

    <!-- Lightning bolt, joining the two marks. -->
    <item
        android:width="14dp"
        android:height="22dp"
        android:left="47dp"
        android:gravity="left|center_vertical">
        <vector
            android:width="14dp"
            android:height="22dp"
            android:viewportWidth="18"
            android:viewportHeight="29">
            <path
                android:fillColor="#FF5A5F"
                android:pathData="M13,0L0,17H8L5,29L18,12H10Z" />
        </vector>
    </item>

    <!-- Nightscout -->
    <item
        android:width="18dp"
        android:height="18dp"
        android:left="66dp"
        android:gravity="left|center_vertical">
        <bitmap android:src="@drawable/ic_myscout" />
    </item>

</layer-list>
